{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SemiContinuity",
  "description": "Semi continuity",
  "oneOf": [
    {
      "description": "`f(x-) = f(x)`\n\n```txt o--------- | ----------x ```",
      "type": "string",
      "enum": [
        "left_continuous"
      ]
    },
    {
      "description": "`f(x) = f(x+)`\n\n```txt x--------- | ----------o ```",
      "type": "string",
      "enum": [
        "right_continuous"
      ]
    }
  ]
}