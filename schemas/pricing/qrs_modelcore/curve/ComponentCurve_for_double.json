          "type": "string",
          "enum": [
            "zero_rate_lerp"
          ]
        },
        "zero_rate": {
          "description": "Zero rate curve, which is a function from datetime to annualized(ACT/365Fixed) rate.",
          "allOf": [
            {
              "$ref": "#/definitions/Lerp1d_for_DateTime_and_RateAct365f_for_double"
            }
          ]
        }
      }
    },
    {
      "type": "object",
      "required": [
        "base_date",
        "type",
        "zero_rate"
      ],
      "properties": {
        "base_date": {
          "description": "Base date of zero rates.",
          "allOf": [
            {
              "$ref": "#/definitions/DateTime"
            }
          ]
        },
        "type": {
          "type": "string",
          "enum": [
            "zero_rate_cr"
          ]
        },
        "zero_rate": {
          "description": "Zero rate curve, which is a function from datetime to annualized(ACT/365Fixed) rate.",
          "allOf": [
            {
              "$ref": "#/definitions/CHermite1d_for_DateTime_and_RateAct365f_for_double_and_CatmullRomScheme"
            }
          ]
        }
      }
    },
    {
      "description": "A curve based on instant forward rates.",
      "type": "object",
      "required": [
        "instant_forward_rate",
        "type"
      ],
      "properties": {
        "instant_forward_rate": {
          "description": "Forward rate curve, which is a function from datetime to annualized(ACT/365Fixed) rate.",
          "allOf": [
