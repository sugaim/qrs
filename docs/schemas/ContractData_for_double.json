{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ContractData_for_double",
  "type": "object",
  "required": [
    "collateral"
  ],
  "properties": {
    "cashflows": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/Cashflow_for_VariableTypesForData_for_double"
      }
    },
    "collateral": {
      "$ref": "#/definitions/Collateral"
    },
    "constants": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/Constant"
      }
    },
    "legs": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/Leg_for_VariableTypesForData_for_double"
      }
    },
    "markets": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/Market"
      }
    },
    "processes": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/Process_for_VariableTypesForData_for_double"
      }
    }
  },
  "definitions": {
    "CalendarSymbol": {
      "description": "A symbol for a calendar. Combined calendars are available. As an atom, only alphanumeric characters or '_' are allowed.",
      "examples": [
        "TK",
        "TK|NY",
        "TK&NY",
        "(TK|NY)&(LN|TK)"
      ],
      "type": "string"
    },
    "Cashflow_for_VariableTypesForData_for_double": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "accrued_daycount",
            "coupon_base",
            "rate",
            "type"
          ],
          "properties": {
            "accrued_daycount": {
              "$ref": "#/definitions/ValueOrId_for_DayCountSymbol"
            },
            "coupon_base": {
              "$ref": "#/definitions/CouponBase_for_VariableTypesForData_for_double"
            },
            "rate": {
              "$ref": "#/definitions/ValueOrId_for_double"
            },
            "rounding": {
              "description": "rounding method for calculate coupon amount",
              "$ref": "#/definitions/ValueOrId_for_Rounding"
            },
            "type": {
              "type": "string",
              "const": "fixed_coupon"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "convention",
            "coupon_base",
            "reference_rate",
            "type"
          ],
          "properties": {
            "convention": {
              "$ref": "#/definitions/ValueOrId_for_InArrears_for_DayCountSymbol_and_CalendarSymbol"
            },
            "coupon_base": {
              "$ref": "#/definitions/CouponBase_for_VariableTypesForData_for_double"
            },
            "gearing": {
              "$ref": "#/definitions/ValueOrId_for_double"
            },
            "reference_rate": {
              "$ref": "#/definitions/Id"
            },
            "rounding": {
              "description": "rounding method for calculate coupon amount",
              "$ref": "#/definitions/ValueOrId_for_Rounding"
            },
            "spread": {
              "$ref": "#/definitions/ValueOrId_for_double"
            },
            "type": {
              "type": "string",
              "const": "overnight_index_coupon"
            }
          }
        }
      ]
    },
    "Ccy": {
      "type": "string",
      "enum": [
        "JPY",
        "USD"
      ]
    },
    "Collateral": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "ccy",
            "type"
          ],
          "properties": {
            "ccy": {
              "$ref": "#/definitions/Ccy"
            },
            "type": {
              "type": "string",
              "const": "money"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "company",
            "type"
          ],
          "properties": {
            "company": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "const": "share"
            }
          }
        }
      ]
    },
    "Constant": {
      "description": "Constant value refered from contract data",
      "oneOf": [
        {
          "type": "number",
          "format": "double"
        },
        {
          "type": "boolean"
        },
        {
          "type": "string"
        },
        {
          "type": "object",
          "additionalProperties": true
        }
      ]
    },
    "CouponBase_for_VariableTypesForData_for_double": {
      "type": "object",
      "required": [
        "daycount",
        "entitle",
        "notional",
        "payment",
        "period_end",
        "period_start"
      ],
      "properties": {
        "daycount": {
          "description": "Day count convention to calculate dcf of accrual period",
          "$ref": "#/definitions/ValueOrId_for_DayCountSymbol"
        },
        "entitle": {
          "description": "A date which the right of the coupon is granted",
          "$ref": "#/definitions/ValueOrId_for_DateWithTag_for_String"
        },
        "notional": {
          "description": "Notional amount",
          "$ref": "#/definitions/ValueOrId_for_Money_for_double"
        },
        "payment": {
          "description": "Payment date",
          "$ref": "#/definitions/ValueOrId_for_DateWithTag_for_String"
        },
        "period_end": {
          "description": "Accrual period end date",
          "$ref": "#/definitions/ValueOrId_for_DateWithTag_for_String"
        },
        "period_start": {
          "description": "Accrual period start date",
          "$ref": "#/definitions/ValueOrId_for_DateWithTag_for_String"
        }
      }
    },
    "DateWithTag_for_String": {
      "description": "Date with a time cut tag. Format is 'yyyy-MM-dd@{tag}'",
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}@.*$"
    },
    "DayCountSymbol": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string",
              "const": "act360"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string",
              "const": "act365f"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string",
              "const": "nl360"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type"
          ],
          "properties": {
            "type": {
              "type": "string",
              "const": "nl365"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "calendar",
            "type"
          ],
          "properties": {
            "calendar": {
              "$ref": "#/definitions/CalendarSymbol"
            },
            "type": {
              "type": "string",
              "const": "bd252"
            }
          }
        }
      ]
    },
    "Id": {
      "description": "Id of a component",
      "type": "string",
      "pattern": "^\\$ref/.+$"
    },
    "InArrears_for_DayCountSymbol_and_CalendarSymbol": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "calendar",
            "obsrate_daycount",
            "overall_daycount",
            "type"
          ],
          "properties": {
            "calendar": {
              "description": "Calendar for rate publication.",
              "$ref": "#/definitions/CalendarSymbol"
            },
            "lockout": {
              "description": "Lockout period",
              "type": "integer",
              "format": "int32"
            },
            "lookback": {
              "description": "Lookback convention",
              "$ref": "#/definitions/Lookback"
            },
            "obsrate_daycount": {
              "description": "Day count convention used to calculate dcf of each observation period.",
              "$ref": "#/definitions/DayCountSymbol"
            },
            "overall_daycount": {
              "description": "Day count convention used to calculate dcf of accrual period.",
              "$ref": "#/definitions/DayCountSymbol"
            },
            "rounding": {
              "description": "Rounding for compunded rate",
              "$ref": "#/definitions/Rounding"
            },
            "type": {
              "type": "string",
              "const": "straight"
            },
            "zero_interest_rate_method": {
              "description": "Apply zero floor on each observed rate.",
              "default": false,
              "type": "boolean"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "calendar",
            "obsrate_daycount",
            "overall_daycount",
            "type"
          ],
          "properties": {
            "calendar": {
              "description": "Calendar for rate publication.",
              "$ref": "#/definitions/CalendarSymbol"
            },
            "lockout": {
              "description": "Lockout period",
              "type": "integer",
              "format": "int32"
            },
            "lookback": {
              "description": "Lookback convention",
              "$ref": "#/definitions/Lookback"
            },
            "obsrate_daycount": {
              "description": "Day count convention used to calculate dcf of each observation period.",
              "$ref": "#/definitions/DayCountSymbol"
            },
            "overall_daycount": {
              "description": "Day count convention used to calculate dcf of accrual period.",
              "$ref": "#/definitions/DayCountSymbol"
            },
            "rounding": {
              "description": "Rounding for compunded rate",
              "$ref": "#/definitions/Rounding"
            },
            "type": {
              "type": "string",
              "const": "spread_exclusive"
            },
            "zero_interest_rate_method": {
              "description": "Apply zero floor on each observed rate.",
              "default": false,
              "type": "boolean"
            }
          }
        }
      ]
    },
    "Leg_for_VariableTypesForData_for_double": {
      "type": "object",
      "required": [
        "cashflows",
        "type"
      ],
      "properties": {
        "cashflows": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Id"
          }
        },
        "type": {
          "type": "string",
          "const": "straight"
        }
      }
    },
    "Lookback": {
      "description": "Lookback convention\n\nWith `n` day lookback, rate applied on today is a observed rate `n` days ago.\n\nIf tomorrow is Friday, the rate is applied three days(today, tomorrow, and the day after tomorrow). (For simplicity, we assume that we do not have any special holidays around today)\n\nBut with observation shift, this date counting is also shifted in addition to applied rate. That is, in 2 days lookback with days observation shift, the number of days is counted 1 because date counting is also started from Wednesday.",
      "oneOf": [
        {
          "type": "object",
          "required": [
            "days",
            "type"
          ],
          "properties": {
            "days": {
              "type": "integer",
              "format": "int32"
            },
            "type": {
              "type": "string",
              "const": "without_observation_shift"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "days",
            "type"
          ],
          "properties": {
            "days": {
              "type": "integer",
              "format": "int32"
            },
            "type": {
              "type": "string",
              "const": "observation_shift"
            }
          }
        }
      ]
    },
    "Market": {
      "type": "object",
      "required": [
        "reference",
        "type"
      ],
      "properties": {
        "reference": {
          "$ref": "#/definitions/OvernightRate"
        },
        "type": {
          "type": "string",
          "const": "overnight_rate"
        }
      }
    },
    "MinSized1_for_Array_of_Id": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Id"
      },
      "minItems": 1
    },
    "MinSized1_for_Array_of_MinSized1_for_Map_of_ValueOrId_for_double": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/MinSized1_for_Map_of_ValueOrId_for_double"
      },
      "minItems": 1
    },
    "MinSized1_for_Array_of_ValueOrId_for_double": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ValueOrId_for_double"
      },
      "minItems": 1
    },
    "MinSized1_for_Map_of_ValueOrId_for_double": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/definitions/ValueOrId_for_double"
      }
    },
    "Money_for_double": {
      "type": "object",
      "required": [
        "amount",
        "ccy"
      ],
      "properties": {
        "amount": {
          "type": "number",
          "format": "double"
        },
        "ccy": {
          "$ref": "#/definitions/Ccy"
        }
      }
    },
    "OvernightRate": {
      "type": "string",
      "enum": [
        "TONA",
        "SOFR"
      ]
    },
    "Process_for_VariableTypesForData_for_double": {
      "oneOf": [
        {
          "type": "object",
          "required": [
            "series",
            "type"
          ],
          "properties": {
            "series": {
              "$ref": "#/definitions/MinSized1_for_Array_of_MinSized1_for_Map_of_ValueOrId_for_double"
            },
            "type": {
              "type": "string",
              "const": "deterministic_number"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "type",
            "values"
          ],
          "properties": {
            "type": {
              "type": "string",
              "const": "constant_number"
            },
            "values": {
              "$ref": "#/definitions/MinSized1_for_Array_of_ValueOrId_for_double"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "references",
            "type"
          ],
          "properties": {
            "references": {
              "$ref": "#/definitions/MinSized1_for_Array_of_Id"
            },
            "type": {
              "type": "string",
              "const": "market_ref"
            }
          }
        },
        {
          "type": "object",
          "required": [
            "denom",
            "numer",
            "type"
          ],
          "properties": {
            "denom": {
              "$ref": "#/definitions/Id"
            },
            "numer": {
              "$ref": "#/definitions/Id"
            },
            "type": {
              "type": "string",
              "const": "ratio"
            }
          }
        }
      ]
    },
    "Rounding": {
      "type": "object",
      "required": [
        "scale",
        "strategy"
      ],
      "properties": {
        "scale": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "strategy": {
          "$ref": "#/definitions/RoundingStrategy"
        }
      }
    },
    "RoundingStrategy": {
      "type": "string",
      "enum": [
        "nearest_even",
        "nearest_integer",
        "to_zero",
        "away_from_zero",
        "to_negative_infinity",
        "to_positive_infinity"
      ]
    },
    "ValueOrId_for_DateWithTag_for_String": {
      "anyOf": [
        {
          "$ref": "#/definitions/Id"
        },
        {
          "$ref": "#/definitions/DateWithTag_for_String"
        }
      ]
    },
    "ValueOrId_for_DayCountSymbol": {
      "anyOf": [
        {
          "$ref": "#/definitions/Id"
        },
        {
          "$ref": "#/definitions/DayCountSymbol"
        }
      ]
    },
    "ValueOrId_for_InArrears_for_DayCountSymbol_and_CalendarSymbol": {
      "anyOf": [
        {
          "$ref": "#/definitions/Id"
        },
        {
          "$ref": "#/definitions/InArrears_for_DayCountSymbol_and_CalendarSymbol"
        }
      ]
    },
    "ValueOrId_for_Money_for_double": {
      "anyOf": [
        {
          "$ref": "#/definitions/Id"
        },
        {
          "$ref": "#/definitions/Money_for_double"
        }
      ]
    },
    "ValueOrId_for_Rounding": {
      "anyOf": [
        {
          "$ref": "#/definitions/Id"
        },
        {
          "$ref": "#/definitions/Rounding"
        }
      ]
    },
    "ValueOrId_for_double": {
      "anyOf": [
        {
          "$ref": "#/definitions/Id"
        },
        {
          "type": "number",
          "format": "double"
        }
      ]
    }
  }
}